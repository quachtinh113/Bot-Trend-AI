# ====================================================================
# GIA CAT SECURE LIVE RUNTIME CONFIGURATION TEMPLATE (.env.example)
# ====================================================================
# HƯỚNG DẪN: Sao chép tệp này thành ".env" và điền các thông tin của bạn.
# KHÔNG ĐƯỢC chia sẻ hoặc commit tệp ".env" chứa mật khẩu thực tế lên git!

# --- THÔNG TIN TÀI KHOẢN MT5 (Dành cho Python-MT5 Bridge)
MT5_LOGIN=12345678
MT5_PASSWORD=YourSecurePasswordHere
MT5_SERVER=Exness-MT5Trial1
# Đường dẫn tùy chọn tới tệp terminal64.exe (nếu cài đặt ngoài thư mục mặc định)
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# --- THÔNG TIN TELEGRAM NOTIFICATION BOT
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-987654321

# --- CHẾ ĐỘ VẬN HÀNH AN TOÀN (demo vs real)
# ENV_MODE: Nhận giá trị "DEMO" hoặc "REAL"
ENV_MODE=DEMO
# ALLOW_REAL_TRADING: Khóa cứng tài khoản thực. Đặt true để cho phép trade tiền thật.
ALLOW_REAL_TRADING=false

# --- CÁC NGƯỠNG RỦI RO SINH TỒN CỐT LÕI (%)
MAX_DAILY_DD_PERCENT=2.0
MAX_WEEKLY_DD_PERCENT=5.0
HARD_KILL_DD_PERCENT=8.0
